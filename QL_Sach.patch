+        <div th:each="bl : ${binhLuanList}" class="binh-luan-card">
+            <div class="binh-luan-header">
+                <img th:src="@{${bl.taiKhoan.avatar} ?: 'https://ui-avatars.com/api/?name=' + ${bl.taiKhoan.hoTen} + '&background=1877f2&color=fff&size=50'}"
+                     alt="Avatar" class="binh-luan-avatar">
+                <div class="binh-luan-info">
+                    <div class="binh-luan-name">
+                        <span th:text="${bl.taiKhoan.hoTen} ?: ${bl.taiKhoan.username}"></span>
+                    </div>
+                    <div class="binh-luan-time">
+                        <i class="far fa-clock"></i>
+                        <span th:text="${#temporals.format(bl.ngayDang, 'dd/MM/yyyy HH:mm')}"></span>
+                    </div>
+                </div>
+                <a th:if="${currentUser?.id == bl.taiKhoan.id || currentUser?.quyen == 1}"
+                   th:href="@{/dien-dan/xoa/{id}(id=${bl.id})}" 
+                   style="color: var(--danger-color);"
+                   onclick="return confirm('Xóa bình luận này?')">
+                    <i class="fas fa-trash"></i>
+                </a>
+            </div>
+            <div class="binh-luan-content" th:text="${bl.noiDung}"></div>
+        </div>
+    </main>
+</div>
+</body>
+</html>
