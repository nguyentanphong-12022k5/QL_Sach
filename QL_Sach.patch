+<!DOCTYPE html>
+<html xmlns:th="http://www.thymeleaf.org">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title>Đăng Ký - Thư Viện</title>
+    <link rel="stylesheet" th:href="@{/css/style.css}">
+    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
+</head>
+<body>
+    <div class="auth-container">
+        <div class="auth-card">
+            <div class="auth-header">
+                <i class="fas fa-user-plus"></i>
+                <h2>Đăng Ký Tài Khoản</h2>
+                <p>Hệ thống quản lý thư viện</p>
+            </div>
+
+            <div th:if="${error}" class="alert alert-error">
+                <i class="fas fa-exclamation-circle"></i>
+                <span th:text="${error}">Lỗi</span>
+            </div>
+
+            <form th:action="@{/register}" method="post" th:object="${taiKhoan}">
+                <div class="form-group">
+                    <label><i class="fas fa-user"></i> Tên đăng nhập</label>
+                    <input type="text" th:field="*{username}" placeholder="Nhập tên đăng nhập" required>
+                </div>
+
+                <div class="form-group">
+                    <label><i class="fas fa-user-circle"></i> Họ tên</label>
+                    <input type="text" th:field="*{hoTen}" placeholder="Nhập họ tên" required>
+                </div>
+
+                <div class="form-group">
+                    <label><i class="fas fa-envelope"></i> Email</label>
+                    <input type="email" th:field="*{email}" placeholder="Nhập email" required>
+                </div>
+
+                <div class="form-group">
+                    <label><i class="fas fa-lock"></i> Mật khẩu</label>
+                    <input type="password" th:field="*{password}" placeholder="Nhập mật khẩu" required>
+                </div>
+
+                <div class="form-group">
+                    <label><i class="fas fa-lock"></i> Xác nhận mật khẩu</label>
+                    <input type="password" name="confirmPassword" placeholder="Nhập lại mật khẩu" required>
+                </div>
+
+                <button type="submit" class="btn btn-primary btn-block">
+                    <i class="fas fa-user-plus"></i> Đăng Ký
+                </button>
+            </form>
+
+            <div class="auth-footer">
+                <p>Đã có tài khoản? <a th:href="@{/login}">Đăng nhập ngay</a></p>
+            </div>
+        </div>
+    </div>
+</body>
+</html>
