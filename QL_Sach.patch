+            </div>
+
+            <div class="form-group">
+                <label><i class="fas fa-user"></i> Tác Giả <span style="color: red;">*</span></label>
+                <select th:field="*{tacGia.id}" class="form-control" required>
+                    <option value="">-- Chọn tác giả --</option>
+                    <option th:each="tg : ${tacGiaList}" th:value="${tg.id}" th:text="${tg.tenTacGia}"></option>
+                </select>
+            </div>
+
+            <div class="form-group">
+                <label><i class="fas fa-building"></i> Nhà Xuất Bản <span style="color: red;">*</span></label>
+                <select th:field="*{nhaXuatBan.id}" class="form-control" required>
+                    <option value="">-- Chọn NXB --</option>
+                    <option th:each="nxb : ${nxbList}" th:value="${nxb.id}" th:text="${nxb.tenNhaXuatBan}"></option>
+                </select>
+            </div>
+
+            <div class="form-group">
+                <label><i class="fas fa-tag"></i> Loại Sách <span style="color: red;">*</span></label>
+                <select th:field="*{loaiSach.id}" class="form-control" required>
+                    <option value="">-- Chọn loại sách --</option>
+                    <option th:each="ls : ${loaiSachList}" th:value="${ls.id}" th:text="${ls.tenLoaiSach}"></option>
+                </select>
+            </div>
+
+            <div class="form-group">
+                <label><i class="fas fa-map-pin"></i> Kệ Sách <span style="color: red;">*</span></label>
+                <select th:field="*{keSach.id}" class="form-control" required>
+                    <option value="">-- Chọn kệ sách --</option>
+                    <option th:each="ks : ${keSachList}" th:value="${ks.id}" th:text="${ks.viTri}"></option>
+                </select>
+            </div>
+
+            <div class="form-group">
+                <label><i class="fas fa-calendar"></i> Năm Xuất Bản</label>
+                <input type="number" th:field="*{namXB}" class="form-control" placeholder="Nhập năm xuất bản" min="1900" max="2026" />
