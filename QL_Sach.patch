+    flex: 1;
+}
+.binh-luan-name {
+    font-weight: 600;
+    color: var(--dark-color);
+}
+.binh-luan-time {
+    font-size: 0.85rem;
+    color: var(--gray-color);
+}
+.binh-luan-content {
+    padding: 10px 0 10px 65px;
+    line-height: 1.6;
+}
