diff --git a/src/main/resources/templates/docgia/list.html b/src/main/resources/templates/docgia/list.html
new file mode 100644
index 0000000..4f55f15
--- /dev/null
+++ b/src/main/resources/templates/docgia/list.html
@@ -0,0 +1,100 @@
+<!doctype html>
+<html xmlns:th="http://www.thymeleaf.org">
+<head>
+<meta charset="UTF-8" />
+<meta name="viewport" content="width=device-width, initial-scale=1.0" />
+<title>Danh Sách Độc Giả - Thư Viện</title>
+<link rel="stylesheet" th:href="@{/css/style.css}" />
+<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
+</head>
+<body>
+<div class="container">
+    <header class="header fade-in">
+        <h1><i class="fas fa-users"></i> Danh Sách Độc Giả</h1>
+        <nav class="nav">
+            <a th:href="@{/}" class="nav-link"><i class="fas fa-home"></i> Trang Chủ</a>
+            <a th:href="@{/sach}" class="nav-link"><i class="fas fa-book"></i> Sách</a>
+            <a th:href="@{/phieumuon}" class="nav-link"><i class="fas fa-hand-holding"></i> Phiếu Mượn</a>
+            <a th:href="@{/thongke}" class="nav-link"><i class="fas fa-chart-bar"></i> Thống Kê</a>
+            <a th:href="@{/dien-dan}" class="nav-link"><i class="fas fa-comments"></i> Diễn Đàn</a>
+            
+        </nav>
+    </header>
+
+    <main class="main fade-in">
+        <!-- Success Message -->
+        <div th:if="${success}" class="alert alert-success">
+            <i class="fas fa-check-circle"></i> <span th:text="${success}"></span>
+        </div>
+
+        <!-- Search Bar -->
+        <div style="margin-bottom: 30px; display: flex; gap: 15px">
+            <div style="flex: 1; position: relative">
+                <i class="fas fa-search" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--gray-color);"></i>
+                <input type="text" id="searchInput" th:value="${keyword}" placeholder="Tìm kiếm theo tên hoặc số điện thoại..."
+                    style="width: 100%; padding: 12px 20px 12px 45px; border: 2px solid #e0e0e0; border-radius: 50px; font-size: 1rem;" />
+            </div>
+            <button class="btn btn-primary" onclick="searchDocGia()"><i class="fas fa-search"></i> Tìm</button>
+            <a th:href="@{/docgia}" class="btn btn-outline"><i class="fas fa-sync-alt"></i> Làm Mới</a>
+            <a th:href="@{/docgia/add}" class="btn btn-success"><i class="fas fa-plus"></i> Thêm Độc Giả</a>
+        </div>
+
+        <!-- Search Result -->
+        <div th:if="${keyword != null}" class="search-result-info">
+            <span>Kết quả tìm kiếm: <span th:text="${resultCount}">0</span> độc giả</span>
+            <a th:href="@{/docgia}" class="clear-search"><i class="fas fa-times"></i> Xóa</a>
+        </div>
+
+        <!-- Table -->
+        <div class="table-wrapper">
+            <table>
+                <thead>
+                    <tr>
+                        <th>Mã ĐG</th>
+                        <th>Họ Tên</th>
+                        <th>Giới Tính</th>
+                        <th>Số Điện Thoại</th>
+                        <th>Địa Chỉ</th>
+                        <th>Trạng Thái</th>
+                        <th>Thao Tác</th>
+                    </tr>
+                </thead>
+                <tbody>
+                    <tr th:each="dg : ${docGiaList}">
+                        <td th:text="${dg.id}">1</td>
+                        <td th:text="${dg.hoTen}">Nguyễn Văn A</td>
+                        <td th:text="${dg.gioiTinh} ?: '--'">Nam</td>
+                        <td th:text="${dg.soDienThoai}">0123456789</td>
+                        <td th:text="${dg.diaChi} ?: '--'">Hà Nội</td>
+                        <td>
+                            <span th:if="${dg.trangThai == 1}" class="badge badge-success">Hoạt động</span>
+                            <span th:unless="${dg.trangThai == 1}" class="badge badge-danger">Khóa</span>
+                        </td>
+                        <td>
+                            <a th:href="@{/docgia/view/{id}(id=${dg.id})}" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i></a>
+                            <a th:href="@{/docgia/edit/{id}(id=${dg.id})}" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
+                            <a th:href="@{/docgia/delete/{id}(id=${dg.id})}" class="btn btn-danger btn-sm" onclick="return confirm('Xóa độc giả này?')"><i class="fas fa-trash"></i></a>
+                        </td>
+                    </tr>
+                </tbody>
+            </table>
+        </div>
+    </main>
+
+    <footer class="footer">
+        <p>&copy; 2026 Quản Lý Thư Viện. All rights reserved.</p>
+    </footer>
+</div>
+
+<script>
+    document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
+        if (e.key === 'Enter') searchDocGia();
+    });
+    function searchDocGia() {
+        var keyword = document.getElementById('searchInput').value.trim();
+        if (keyword) window.location.href = '/docgia?keyword=' + encodeURIComponent(keyword);
+        else window.location.href = '/docgia';
+    }
+</script>
+</body>
+</html>
