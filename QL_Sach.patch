+++ b/src/main/resources/templates/dien-dan/index.html
@@ -0,0 +1,291 @@
+<!DOCTYPE html>
+<html xmlns:th="http://www.thymeleaf.org">
+<head>
+<meta charset="UTF-8">
+<meta name="viewport" content="width=device-width, initial-scale=1.0">
+<title>Diễn Đàn - Thư Viện</title>
+<link rel="stylesheet" th:href="@{/css/style.css}">
+<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
+<style>
+.dien-dan-container {
+    max-width: 1000px;
+    margin: 40px auto;
+}
+.binh-luan-card {
+    background: white;
+    border-radius: 16px;
+    padding: 20px;
+    margin-bottom: 20px;
+    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
+}
+.binh-luan-header {
+    display: flex;
+    align-items: center;
+    gap: 15px;
+    margin-bottom: 15px;
+}
+.binh-luan-avatar {
+    width: 50px;
+    height: 50px;
+    border-radius: 50%;
+    object-fit: cover;
+}
+.binh-luan-info {
+    flex: 1;
+}
+.binh-luan-name {
+    font-weight: 600;
+    color: var(--dark-color);
+}
+.binh-luan-time {
+    font-size: 0.85rem;
+    color: var(--gray-color);
+}
+.binh-luan-content {
+    padding: 10px 0 10px 65px;
+    line-height: 1.6;
+}
+.form-binh-luan {
+    background: white;
+    border-radius: 16px;
+    padding: 25px;
+    margin-bottom: 30px;
+    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
+}
+.form-binh-luan textarea {
+    width: 100%;
+    padding: 15px;
+    border: 2px solid #e0e0e0;
+    border-radius: 12px;
+    resize: vertical;
+    min-height: 100px;
+    font-size: 1rem;
+}
+.form-binh-luan textarea:focus {
+    border-color: var(--primary-color);
+    outline: none;
+}
+.sidebar {
+    background: white;
+    border-radius: 16px;
+    padding: 20px;
+    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
+}
+.sidebar-title {
+    font-size: 1.2rem;
+    font-weight: 600;
+    margin-bottom: 15px;
+    padding-bottom: 10px;
+    border-bottom: 2px solid var(--primary-color);
+}
+.sidebar-item {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    padding: 10px 0;
+    border-bottom: 1px solid #eee;
+}
+.sidebar-item:last-child {
+    border-bottom: none;
+}
+.btn-action {
+    opacity: 0.6;
+    transition: opacity 0.2s;
+    margin-left: 8px;
+}
+.btn-action:hover {
+    opacity: 1;
+}
+</style>
+</head>
+<body>
+<div class="container">
+    <header class="header fade-in">
+        <h1><i class="fas fa-comments"></i> Diễn Đàn</h1>
+        <nav class="nav">
+            <a th:href="@{/}" class="nav-link"><i class="fas fa-home"></i> Trang Chủ</a>
+            <a th:href="@{/sach}" class="nav-link"><i class="fas fa-book"></i> Sách</a>
+            <a th:href="@{/dien-dan}" class="nav-link"><i class="fas fa-comments"></i> Diễn Đàn</a>
+            <a th:if="${currentUser?.quyen == 1}" th:href="@{/dien-dan/admin}" class="nav-link">
+                <i class="fas fa-cog"></i> Quản Lý
+            </a>
+            <!-- Avatar dropdown -->
