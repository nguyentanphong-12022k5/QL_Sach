+<!doctype html>
+<html xmlns:th="http://www.thymeleaf.org">
+<head>
+<meta charset="UTF-8" />
+<meta name="viewport" content="width=device-width, initial-scale=1.0" />
+<title th:text="${docGia.id != null ? 'Sửa Độc Giả' : 'Thêm Độc Giả'}">Form Độc Giả</title>
+<link rel="stylesheet" th:href="@{/css/style.css}" />
+<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
+</head>
+<body>
+<div class="container">
+    <header class="header fade-in">
+        <h1><i class="fas fa-user-plus"></i> <span th:text="${docGia.id != null ? 'Sửa Độc Giả' : 'Thêm Độc Giả Mới'}"></span></h1>
+        <nav class="nav">
+            <a th:href="@{/docgia}" class="nav-link"><i class="fas fa-arrow-left"></i> Quay Lại</a>
+        </nav>
+    </header>
+
+    <main class="main fade-in">
+        <form th:action="@{/docgia/save}" method="post" th:object="${docGia}" style="max-width: 600px; margin: 0 auto;">
+            <input type="hidden" th:field="*{id}" />
+            
+            <div class="form-group">
+                <label><i class="fas fa-user"></i> Họ Tên <span style="color: red;">*</span></label>
+                <input type="text" th:field="*{hoTen}" class="form-control" placeholder="Nhập họ tên" required />
+            </div>
+            
+            <div class="form-group">
+                <label><i class="fas fa-venus-mars"></i> Giới Tính</label>
+                <select th:field="*{gioiTinh}" class="form-control">
+                    <option value="">-- Chọn giới tính --</option>
+                    <option value="Nam">Nam</option>
+                    <option value="Nữ">Nữ</option>
+                    <option value="Khác">Khác</option>
+                </select>
+            </div>
+            
+            <div class="form-group">
+                <label><i class="fas fa-phone"></i> Số Điện Thoại <span style="color: red;">*</span></label>
+                <input type="text" th:field="*{soDienThoai}" class="form-control" placeholder="Nhập số điện thoại" required />
+            </div>
+            
+            <div class="form-group">
+                <label><i class="fas fa-map-marker-alt"></i> Địa Chỉ</label>
+                <textarea th:field="*{diaChi}" class="form-control" rows="3" placeholder="Nhập địa chỉ"></textarea>
+            </div>
+            
+            <div class="form-group">
+                <label><i class="fas fa-toggle-on"></i> Trạng Thái</label>
+                <select th:field="*{trangThai}" class="form-control">
+                    <option value="1">Hoạt động</option>
+                    <option value="0">Khóa</option>
+                </select>
+            </div>
+            
+            <div style="display: flex; gap: 15px; margin-top: 30px;">
+                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
+                <a th:href="@{/docgia}" class="btn btn-outline"><i class="fas fa-times"></i> Hủy</a>
+            </div>
+        </form>
+    </main>
+</div>
+</body>
+</html>
